{
  "name": "capacities-mcp",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "capacities-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --transport http --port 3000",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http --port 3000",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "keywords": ["mcp", "capacities", "rag", "knowledge-base"],
  "description": "MCP server for Capacities note-taking app - RAG knowledge base connector",
  "license": "MIT",
  "dependencies": {
    "fastmcp": "^1.27.3",
    "zod": "^3.24.4",
    "gray-matter": "^4.0.3",
    "unzipper": "^0.12.3",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0"
  }
}
